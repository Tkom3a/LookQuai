# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channel (username with @ or channel ID)
# Example: @my_channel or -1001234567890
TELEGRAM_CHANNEL=@your_channel_username

# Trading pair (default: QUAIUSDT)
SYMBOL=QUAIUSDT

# Price change threshold for UP notification (default: 4.0)
THRESHOLD_UP=4.0

# Price change threshold for DOWN notification (default: 4.0)
THRESHOLD_DOWN=4.0

# Time period in minutes to monitor (default: 5)
LOOKBACK_MINUTES=5
